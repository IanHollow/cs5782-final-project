% Gemini color theme adapted for the DoRA commonsense reasoning poster.
% Base theme: https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

\definecolor{NvidiaGreen}{RGB}{118, 185, 0}
\definecolor{NvidiaGreenDark}{RGB}{71, 112, 0}
\definecolor{NvidiaGreenLight}{RGB}{238, 247, 227}
\definecolor{MicrosoftBlue}{RGB}{0, 120, 212}
\definecolor{MicrosoftBlueDark}{RGB}{0, 72, 128}
\definecolor{Ink}{RGB}{23, 33, 47}
\definecolor{SoftGray}{RGB}{246, 248, 251}
\definecolor{WarmGray}{RGB}{249, 250, 247}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=Ink,bg=white}
\setbeamercolor{palette secondary}{fg=Ink,bg=white}
\setbeamercolor{palette tertiary}{bg=Ink,fg=white}
\setbeamercolor{palette quaternary}{fg=Ink,bg=white}
\setbeamercolor{structure}{fg=NvidiaGreenDark}

% Headline
\setbeamercolor{headline}{fg=white,bg=Ink}
\setbeamercolor{headline rule}{bg=NvidiaGreen}

% Block
\setbeamercolor{block title}{fg=Ink,bg=white}
\setbeamercolor{block separator}{bg=NvidiaGreen}
\setbeamercolor{block body}{fg=Ink,bg=white}

% Alert Block
\setbeamercolor{block title alerted}{fg=white,bg=NvidiaGreenDark}
\setbeamercolor{block separator alerted}{bg=MicrosoftBlue}
\setbeamercolor{block body alerted}{fg=Ink,bg=NvidiaGreenLight}

% Example Block
\setbeamercolor{block title example}{fg=Ink,bg=WarmGray}
\setbeamercolor{block separator example}{bg=NvidiaGreen}
\setbeamercolor{block body example}{fg=Ink,bg=WarmGray}

% Heading
\setbeamercolor{heading}{fg=NvidiaGreenDark}

% Itemize
\setbeamercolor{item}{fg=NvidiaGreenDark}

% Bibliography
\setbeamercolor{bibliography item}{fg=Ink}
\setbeamercolor{bibliography entry author}{fg=Ink}
\setbeamercolor{bibliography entry title}{fg=Ink}
\setbeamercolor{bibliography entry location}{fg=Ink}
\setbeamercolor{bibliography entry note}{fg=Ink}
