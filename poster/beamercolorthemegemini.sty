% Gemini color theme adapted for the DoRA commonsense reasoning poster.
% Base theme: https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

\definecolor{LoraxOrange}{RGB}{253, 185, 69}
\definecolor{LoraxOrangeDark}{RGB}{173, 76, 10}
\definecolor{LoraxOrangeLight}{RGB}{255, 247, 227}
\definecolor{DoraemonBlue}{RGB}{0, 154, 216}
\definecolor{DoraemonBlueDark}{RGB}{0, 99, 193}
\definecolor{DoraemonBlueLight}{RGB}{230, 246, 253}
\definecolor{Ink}{RGB}{23, 33, 47}
\definecolor{SoftGray}{RGB}{246, 248, 251}
\definecolor{WarmGray}{RGB}{250, 250, 249}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=Ink,bg=white}
\setbeamercolor{palette secondary}{fg=Ink,bg=white}
\setbeamercolor{palette tertiary}{bg=Ink,fg=white}
\setbeamercolor{palette quaternary}{fg=Ink,bg=white}
\setbeamercolor{structure}{fg=DoraemonBlueDark}

% Headline
\setbeamercolor{headline}{fg=Ink,bg=white}
\setbeamercolor{headline rule}{bg=DoraemonBlue}

% Block
\setbeamercolor{block title}{fg=Ink,bg=white}
\setbeamercolor{block separator}{bg=DoraemonBlue}
\setbeamercolor{block body}{fg=Ink,bg=white}

% Alert Block
\setbeamercolor{block title alerted}{fg=white,bg=DoraemonBlue}
\setbeamercolor{block separator alerted}{bg=LoraxOrange}
\setbeamercolor{block body alerted}{fg=Ink,bg=DoraemonBlueLight}

% Example Block
\setbeamercolor{block title example}{fg=Ink,bg=WarmGray}
\setbeamercolor{block separator example}{bg=LoraxOrange}
\setbeamercolor{block body example}{fg=Ink,bg=WarmGray}

% Heading
\setbeamercolor{heading}{fg=DoraemonBlueDark}

% Itemize
\setbeamercolor{item}{fg=DoraemonBlueDark}

% Bibliography
\setbeamercolor{bibliography item}{fg=Ink}
\setbeamercolor{bibliography entry author}{fg=Ink}
\setbeamercolor{bibliography entry title}{fg=Ink}
\setbeamercolor{bibliography entry location}{fg=Ink}
\setbeamercolor{bibliography entry note}{fg=Ink}
