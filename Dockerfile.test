FROM python:3.12-slim

WORKDIR /app

# Get the latest uv package manager (extremely fast installation)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Copy the project files into the container
COPY . .

# Use uv to install dependencies including the test group (pytest, etc.)
RUN uv sync --group test

# Default command to run when the container starts: run all tests
CMD ["uv", "run", "pytest", "code/tests/", "-v"]
